Sub OpenLatestCSVAndConvertToColumns(name As String, workbookCombined As Workbook)
    Dim folderPath As String, latestFile As String, latestDate As Date
    Dim fso As Object, fil As Object
    Dim combinedSheet As Worksheet, execWs As Worksheet
    Dim tempWs As Worksheet, qt As QueryTable
    Dim csvLastRow As Long, combinedLastRow As Long, i As Long, j As Long
    Dim csvTitleCol As Variant, csvStatusCol As Variant, csvUserIDCol As Variant, csvDateCol As Variant
    Dim combinedTitleCol As Variant, combinedStatusCol As Variant, combinedUserIDCol As Variant, combinedDateCol As Variant
    Dim csvData As Object, csvKey As String, courseList As Variant, course As Variant
    Dim newDate As Date, oldDate As Variant
    Dim rawVal As String, datePart As String, sep As String
    Dim parts() As String, d As Long, m As Long, y As Long
    Dim colTypes(1 To 100) As Integer
    Dim cleanCSVId As String, cleanCombinedId As String

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.DisplayAlerts = False 
    Application.Calculation = xlCalculationManual
    On Error GoTo CleanFail

    folderPath = PCM_PATH
    latestFile = "": latestDate = 0
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    ' 1. BUSCAR EL ARCHIVO MÁS RECIENTE
    For Each fil In fso.GetFolder(folderPath).Files
        If fil.name Like "Training History - Raw Data view*" And fil.name Like "*.csv" Then
            If fil.DateLastModified > latestDate Then
                latestDate = fil.DateLastModified
                latestFile = fil.Path
            End If
        End If
    Next fil

    If latestFile = "" Then
        MsgBox "No se encontró ningún archivo CSV.", vbExclamation
        GoTo CleanExit
    End If

    ' 2. IMPORTACIÓN DE CSV FORZANDO TEXTO PLANO
    Set tempWs = workbookCombined.Sheets.Add
    For i = 1 To 100
        colTypes(i) = 2 ' 2 = xlTextFormat
    Next i

    Set qt = tempWs.QueryTables.Add(Connection:="TEXT;" & latestFile, Destination:=tempWs.Range("A1"))
    With qt
        .TextFileParseType = xlDelimited
        .TextFileCommaDelimiter = True
        .TextFileColumnDataTypes = colTypes
        .Refresh BackgroundQuery:=False
    End With

    csvLastRow = tempWs.Cells(tempWs.Rows.Count, 1).End(xlUp).row
    Set combinedSheet = workbookCombined.Sheets(1)
    
    ' Mapeo de columnas
    csvTitleCol = Application.Match("Training Title", tempWs.Rows(1), 0)
    csvStatusCol = Application.Match("Training Record Status", tempWs.Rows(1), 0)
    csvUserIDCol = Application.Match("User - Corporate ID", tempWs.Rows(1), 0)
    csvDateCol = Application.Match("Training Completion Date", tempWs.Rows(1), 0)

    combinedTitleCol = Application.Match("Training - Training title", combinedSheet.Rows(1), 0)
    combinedStatusCol = Application.Match("Training record - Training record status", combinedSheet.Rows(1), 0)
    combinedUserIDCol = Application.Match("User - User ID", combinedSheet.Rows(1), 0)
    combinedDateCol = Application.Match("Training record - Training record completed date", combinedSheet.Rows(1), 0)

    If IsError(csvStatusCol) Or IsError(csvUserIDCol) Or IsError(csvTitleCol) Or IsError(csvDateCol) Then
        MsgBox "Error: No se han encontrado las columnas requeridas en el archivo CSV.", vbCritical
        GoTo CleanExit
    End If

    ' 3. PROCESAR Y CARGAR CSV AL DICCIONARIO
    Set csvData = CreateObject("Scripting.Dictionary")
    
    For i = 2 To csvLastRow
        Dim st As String: st = Trim(CStr(tempWs.Cells(i, CLng(csvStatusCol)).Value))
        
        ' Validación de estado más flexible frente a espacios o variaciones de caracteres
        If InStr(1, st, "Completed", vbTextCompare) > 0 Or InStr(1, st, "Registered", vbTextCompare) > 0 Then
            
            ' NORMALIZACIÓN DE ID (Elimina ceros iniciales si el ID es puramente numérico)
            cleanCSVId = Trim(CStr(tempWs.Cells(i, CLng(csvUserIDCol)).Value))
            If IsNumeric(cleanCSVId) Then cleanCSVId = CStr(Val(cleanCSVId))
            
            csvKey = cleanCSVId & "|" & Trim(CStr(tempWs.Cells(i, CLng(csvTitleCol)).Value))
            rawVal = Trim(tempWs.Cells(i, CLng(csvDateCol)).Value)
            
            If rawVal <> "" Then
                datePart = IIf(InStr(rawVal, " ") > 0, Split(rawVal, " ")(0), rawVal)
                sep = IIf(InStr(datePart, "/") > 0, "/", IIf(InStr(datePart, "-") > 0, "-", ""))
                
                If sep <> "" Then
                    parts = Split(datePart, sep)
                    If UBound(parts) = 2 Then
                        ' DETECTOR INTELIGENTE DE ESTRUCTURA DE FECHA
                        If Len(parts(0)) = 4 Then
                            ' Formato tipo YYYY-MM-DD
                            y = Val(parts(0))
                            m = Val(parts(1))
                            d = Val(parts(2))
                        Else
                            ' Formato tipo DD/MM/YYYY o MM/DD/YYYY
                            d = Val(parts(0))
                            m = Val(parts(1))
                            y = Val(parts(2))
                            If y < 100 Then y = IIf(y >= 30, 1900 + y, 2000 + y)
                        End If
                        
                        ' Control de límites lógicos
                        If m >= 1 And m <= 12 And d >= 1 And d <= 31 Then
                            csvData(csvKey) = DateSerial(y, m, d)
                        End If
                    End If
                End If
            End If
        End If
    Next i

    ' 4. ACTUALIZAR HOJA PRINCIPAL (Combined)
    Set execWs = ThisWorkbook.Sheets("Ejecutar")
    courseList = execWs.Range("G2", execWs.Cells(execWs.Rows.Count, "G").End(xlUp)).Value
    combinedLastRow = combinedSheet.Cells(combinedSheet.Rows.Count, CLng(combinedTitleCol)).End(xlUp).row

    For i = 2 To combinedLastRow
        ' NORMALIZACIÓN DE ID EN LA HOJA DESTINO
        cleanCombinedId = Trim(CStr(combinedSheet.Cells(i, CLng(combinedUserIDCol)).Value))
        If IsNumeric(cleanCombinedId) Then cleanCombinedId = CStr(Val(cleanCombinedId))

        For j = LBound(courseList, 1) To UBound(courseList, 1)
            course = Trim(CStr(courseList(j, 1)))
            
            If InStr(1, CStr(combinedSheet.Cells(i, CLng(combinedTitleCol)).Value), course, vbTextCompare) > 0 Then
                csvKey = cleanCombinedId & "|" & course
                
                If csvData.Exists(csvKey) Then
                    newDate = csvData(csvKey)
                    oldDate = combinedSheet.Cells(i, CLng(combinedDateCol)).Value
                    
                    If Not IsDate(oldDate) Or newDate > CDate(oldDate) Then
                        combinedSheet.Cells(i, CLng(combinedStatusCol)).Value = "Completed"
                        combinedSheet.Cells(i, CLng(combinedDateCol)).Value = newDate
                        combinedSheet.Cells(i, CLng(combinedDateCol)).NumberFormat = "dd/mm/yyyy"
                        combinedSheet.Cells(i, CLng(combinedDateCol)).Interior.Color = RGB(255, 255, 0)
                    End If
                End If
            End If
        Next j
    Next i

CleanExit:
    On Error Resume Next
    If Not tempWs Is Nothing Then tempWs.Delete
    On Error GoTo 0
    
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.DisplayAlerts = True
    Application.Calculation = xlCalculationAutomatic
    Exit Sub
CleanFail:
    MsgBox "Error en proceso de volcado: " & Err.Description
    Resume CleanExit
End Sub
