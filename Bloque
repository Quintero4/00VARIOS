Sub OpenLatestCSVAndConvertToColumns(name As String, workbookCombined As Workbook)
    Dim folderPath As String, latestFile As String, latestDate As Date
    Dim fso As Object, fil As Object
    Dim combinedSheet As Worksheet, execWs As Worksheet
    Dim tempWs As Worksheet, qt As QueryTable
    Dim csvLastRow As Long, combinedLastRow As Long, i As Long, j As Long
    Dim csvTitleCol As Variant, csvStatusCol As Variant, csvUserIDCol As Variant, csvDateCol As Variant
    Dim combinedTitleCol As Variant, combinedStatusCol As Variant, combinedUserIDCol As Variant, combinedDateCol As Variant
    Dim csvData As Object, csvKey As String, courseList As Variant, course As Variant
    Dim newDate As Date, oldDate As Variant, parsedDate As Date
    Dim rawVal As String, datePart As String, sep As String, csvTitle As String
    Dim parts() As String, d As Long, m As Long, y As Long
    Dim colTypes(1 To 100) As Integer
    Dim cleanCSVId As String, cleanCombinedId As String
    Dim col As Long, headerText As String

    Application.ScreenUpdating = False
    Application.EnableEvents = False
    Application.DisplayAlerts = False 
    Application.Calculation = xlCalculationManual
    On Error GoTo CleanFail

    folderPath = PCM_PATH
    latestFile = "": latestDate = 0
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    ' 1. BUSCAR EL ARCHIVO CSV MÁS RECIENTE
    For Each fil In fso.GetFolder(folderPath).Files
        If fil.name Like "Training History - Raw Data view*" And fil.name Like "*.csv" Then
            If fil.DateLastModified > latestDate Then
                latestDate = fil.DateLastModified
                latestFile = fil.Path
            End If
        End If
    Next fil

    If latestFile = "" Then
        MsgBox "No se encontró ningún archivo CSV.", vbExclamation
        GoTo CleanExit
    End If

    ' 2. IMPORTACIÓN DEL CSV CONFIGURADO PARA PUNTO Y COMA (;) Y UTF-8
    Set tempWs = workbookCombined.Sheets.Add
    For i = 1 To 100
        colTypes(i) = 2 ' 2 = xlTextFormat (Fuerza la lectura como texto plano puro)
    Next i

    Set qt = tempWs.QueryTables.Add(Connection:="TEXT;" & latestFile, Destination:=tempWs.Range("A1"))
    With qt
        .TextFilePlatform = 65001 ' Forzar lectura en UTF-8 para neutralizar caracteres BOM invisibles
        .TextFileParseType = xlDelimited
        .TextFileSemicolonDelimiter = True ' Separador por punto y coma corregido
        .TextFileCommaDelimiter = False
        .TextFileColumnDataTypes = colTypes
        .Refresh BackgroundQuery:=False
    End With

    csvLastRow = tempWs.Cells(tempWs.Rows.Count, 1).End(xlUp).row
    Set combinedSheet = workbookCombined.Sheets(1)
    
    ' 3. LOCALIZACIÓN DINÁMICA DE COLUMNAS CRÍTICAS
    csvTitleCol = Empty: csvStatusCol = Empty: csvUserIDCol = Empty: csvDateCol = Empty
    For col = 1 To tempWs.Cells(1, tempWs.Columns.Count).End(xlToLeft).Column
        headerText = tempWs.Cells(1, col).Value
        If InStr(headerText, "Training Title") > 0 Then csvTitleCol = col
        If InStr(headerText, "Training Record Status") > 0 Then csvStatusCol = col
        If InStr(headerText, "User - Corporate ID") > 0 Then csvUserIDCol = col
        If InStr(headerText, "Training Completion Date") > 0 Then csvDateCol = col
    Next col

    combinedTitleCol = Empty: combinedStatusCol = Empty: combinedUserIDCol = Empty: combinedDateCol = Empty
    For col = 1 To combinedSheet.Cells(1, combinedSheet.Columns.Count).End(xlToLeft).Column
        headerText = combinedSheet.Cells(1, col).Value
        If InStr(headerText, "Training - Training title") > 0 Then combinedTitleCol = col
        If InStr(headerText, "Training record - Training record status") > 0 Then combinedStatusCol = col
        If InStr(headerText, "User - User ID") > 0 Then combinedUserIDCol = col
        If InStr(headerText, "Training record - Training record completed date") > 0 Then combinedDateCol = col
    Next col

    If IsEmpty(csvTitleCol) Or IsEmpty(csvStatusCol) Or IsEmpty(csvUserIDCol) Or IsEmpty(csvDateCol) Or _
       IsEmpty(combinedTitleCol) Or IsEmpty(combinedStatusCol) Or IsEmpty(combinedUserIDCol) Or IsEmpty(combinedDateCol) Then
        MsgBox "Error: No se pudieron mapear las columnas correspondientes en los archivos.", vbCritical
        GoTo CleanExit
    End If

    ' Cargar listado oficial de cursos prioritarios para el mapeo previo
    Set execWs = ThisWorkbook.Sheets("Ejecutar")
    courseList = execWs.Range("G2", execWs.Cells(execWs.Rows.Count, "G").End(xlUp)).Value

    ' 4. PROCESAR EL CSV TRATANDO DUPLICADOS Y AGRUPANDO POR CURSO OFICIAL
    Set csvData = CreateObject("Scripting.Dictionary")
    
    For i = 2 To csvLastRow
        Dim st As String: st = Trim(CStr(tempWs.Cells(i, CInt(csvStatusCol)).Value))
        
        ' Aceptar variaciones de estado válidas
        If InStr(1, st, "Completed", vbTextCompare) > 0 Or InStr(1, st, "Registered", vbTextCompare) > 0 Then
            cleanCSVId = Trim(CStr(tempWs.Cells(i, CInt(csvUserIDCol)).Value))
            If IsNumeric(cleanCSVId) Then cleanCSVId = CStr(Val(cleanCSVId))
            
            csvTitle = Trim(CStr(tempWs.Cells(i, CInt(csvTitleCol)).Value))
            
            ' Validar contra la lista oficial para saltarse desajustes de texto en el CSV (como espacios dobles)
            For j = LBound(courseList, 1) To UBound(courseList, 1)
                course = Trim(CStr(courseList(j, 1)))
                
                If InStr(1, csvTitle, course, vbTextCompare) > 0 Then
                    csvKey = cleanCSVId & "|" & course
                    rawVal = Trim(tempWs.Cells(i, CInt(csvDateCol)).Value)
                    
                    If rawVal <> "" Then
                        datePart = IIf(InStr(rawVal, " ") > 0, Split(rawVal, " ")(0), rawVal)
                        sep = IIf(InStr(datePart, "/") > 0, "/", IIf(InStr(datePart, "-") > 0, "-", ""))
                        
                        If sep <> "" Then
                            parts = Split(datePart, sep)
                            If UBound(parts) = 2 Then
                                ' Parseo de fechas estructurado
                                If Len(parts(0)) = 4 Then
                                    y = Val(parts(0)): m = Val(parts(1)): d = Val(parts(2))
                                Else
                                    d = Val(parts(0)): m = Val(parts(1)): y = Val(parts(2))
                                    If y < 100 Then y = IIf(y >= 30, 1900 + y, 2000 + y)
                                End If
                                
                                If m >= 1 And m <= 12 And d >= 1 And d <= 31 Then
                                    parsedDate = DateSerial(y, m, d)
                                    
                                    ' GESTIÓN DE DUPLICADOS: Conservar siempre la fecha de ejecución más reciente del CSV
                                    If csvData.Exists(csvKey) Then
                                        If parsedDate > csvData(csvKey) Then
                                            csvData(csvKey) = parsedDate
                                        End If
                                    Else
                                        csvData(csvKey) = parsedDate
                                    End If
                                End If
                            End If
                        End If
                    End If
                    Exit For ' Match encontrado para esta fila del CSV, pasar a la siguiente
                End If
            Next j
        End If
    Next i

    ' 5. VOLCADO Y ACTUALIZACIÓN EN LA HOJA COMBINED
    combinedLastRow = combinedSheet.Cells(combinedSheet.Rows.Count, CInt(combinedTitleCol)).End(xlUp).row

    For i = 2 To combinedLastRow
        cleanCombinedId = Trim(CStr(combinedSheet.Cells(i, CInt(combinedUserIDCol)).Value))
        If IsNumeric(cleanCombinedId) Then cleanCombinedId = CStr(Val(cleanCombinedId))

        For j = LBound(courseList, 1) To UBound(courseList, 1)
            course = Trim(CStr(courseList(j, 1)))
            
            ' Verificar si la celda de destino contiene el identificador del curso
            If InStr(1, CStr(combinedSheet.Cells(i, CInt(combinedTitleCol)).Value), course, vbTextCompare) > 0 Then
                csvKey = cleanCombinedId & "|" & course
                
                If csvData.Exists(csvKey) Then
                    newDate = csvData(csvKey)
                    oldDate = combinedSheet.Cells(i, CInt(combinedDateCol)).Value
                    
                    ' Guardar la fecha en caso de ser un nuevo registro o una actualización posterior
                    If Not IsDate(oldDate) Or newDate > CDate(oldDate) Then
                        combinedSheet.Cells(i, CInt(combinedStatusCol)).Value = "Completed"
                        combinedSheet.Cells(i, CInt(combinedDateCol)).Value = newDate
                        combinedSheet.Cells(i, CInt(combinedDateCol)).NumberFormat = "dd/mm/yyyy"
                        combinedSheet.Cells(i, CInt(combinedDateCol)).Interior.Color = RGB(255, 255, 0)
                    End If
                End If
            End If
        Next j
    Next i

CleanExit:
    On Error Resume Next
    If Not tempWs Is Nothing Then tempWs.Delete
    On Error GoTo 0
    
    Application.ScreenUpdating = True
    Application.EnableEvents = True
    Application.DisplayAlerts = True
    Application.Calculation = xlCalculationAutomatic
    Exit Sub
CleanFail:
    MsgBox "Error en proceso de volcado: " & Err.Description
    Resume CleanExit
End Sub
